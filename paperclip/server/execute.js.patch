+++ execute.js
@@ buildPrompt() function @@
-    const taskId = cfgString(ctx.config?.taskId);
-    const taskTitle = cfgString(ctx.config?.taskTitle) || "";
-    const taskBody = cfgString(ctx.config?.taskBody) || "";
-    const commentId = cfgString(ctx.config?.commentId) || "";
-    const wakeReason = cfgString(ctx.config?.wakeReason) || "";
+    const taskId = cfgString(ctx.config?.taskId) ?? cfgString(ctx.context?.taskId) ?? cfgString(ctx.context?.issueId);
+    const taskTitle = cfgString(ctx.config?.taskTitle) ?? cfgString(ctx.context?.taskTitle) ?? "";
+    const taskBody = cfgString(ctx.config?.taskBody) ?? cfgString(ctx.context?.taskBody) ?? "";
+    const commentId = cfgString(ctx.config?.commentId) ?? cfgString(ctx.context?.commentId) ?? "";
+    const wakeReason = cfgString(ctx.config?.wakeReason) ?? cfgString(ctx.context?.wakeReason) ?? "";

@@ vars object in buildPrompt() @@
-        paperclipApiUrl,
+        paperclipApiUrl, paperclipApiKey: ctx.authToken || "",

CRITICAL: paperclipApiKey MUST be on the SAME LINE as paperclipApiUrl.
If placed on a new line, it shifts line 133 of the template section which contains
{{#noTask}}. The TSX lexer treats the opening { as JSX and crashes with:
  SyntaxError: Unexpected token at line 133
This is a fatal crash — PM2 will show restart counter climbing rapidly.

@@ execute() function — env block @@
-    const taskId = cfgString(ctx.config?.taskId);
+    const taskId = cfgString(ctx.config?.taskId) ?? cfgString(ctx.context?.taskId) ?? cfgString(ctx.context?.issueId);

@@ execute() function — after PAPERCLIP_RUN_ID @@
-    if (ctx.runId)
-        env.PAPERCLIP_RUN_ID = ctx.runId;
+    if (ctx.runId)
+        env.PAPERCLIP_RUN_ID = ctx.runId;
+    if (ctx.authToken)
+        env.PAPERCLIP_API_KEY = ctx.authToken;
+    if (!env.HOME)
+        env.HOME = "/home/hermes_user";

WHY:
1. ctx.config is runtimeConfig (resolved adapterConfig), but taskId lives in
   ctx.context (contextSnapshot). Without this, {{#taskId}} block is always
   empty and agent falls into {{#noTask}} branch trying to list issues via curl.
2. paperclipApiKey added to template vars so agent can use {{paperclipApiKey}}
   in curl commands for Authorization: Bearer header.
3. PAPERCLIP_API_KEY injected into process env so hermes tools can use it.
4. HOME must be set — hermes_user home may not be in process.env.

FILE: /opt/paperclip/node_modules/.pnpm/hermes-paperclip-adapter@0.2.0/node_modules/hermes-paperclip-adapter/dist/server/execute.js
Apply after every `npm install` or Paperclip update using: bash paperclip/server/restore.sh
